# App
APP_NAME=Labourious
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/labourious.db

# Vault
VAULT_PASSWORD=change-me-in-production
VAULT_SALT=labourious-salt-v1

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Exchange (stored in vault in production — these are fallback env vars)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_TESTNET=true
