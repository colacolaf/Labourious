from typing import Optional
from brokers.base import BrokerConnector
from brokers.alpaca import AlpacaConnector
from brokers.binance import BinanceConnector

logger = logging.getLogger(__name__)

BROKER_REGISTRY = {
    'alpaca': AlpacaConnector,
    'binance': BinanceConnector,
}

def get_connector(
    broker_name: str, 
    vault,  # EncryptedVault instance
    is_paper: bool = True
) -> Optional[BrokerConnector]:
    """
    Factory function to get broker connector instance.
    
    Args:
        broker_name: Key in BROKER_REGISTRY ('alpaca', 'binance')
        vault: EncryptedVault instance for retrieving credentials
        is_paper: For Alpaca, True for paper trading
    
    Returns:
        BrokerConnector subclass instance, or None on failure
    """
    
    if broker_name not in BROKER_REGISTRY:
        logger.error(f"Unknown broker: {broker_name}")
        return None
    
    try:
        # Retrieve credentials from vault
        api_key = vault.retrieve(f"{broker_name}_api_key")
        secret = vault.retrieve(f"{broker_name}_secret")
        
        connector_class = BROKER_REGISTRY[broker_name]
        
        if broker_name == 'alpaca':
            return connector_class(api_key=api_key, secret=secret, is_paper=is_paper)
        else:  # binance
            return connector_class(api_key=api_key, secret=secret)
    
    except Exception as e:
        logger.error(f"Failed to instantiate {broker_name} connector: {e}")
        return None

def list_brokers() -> list[str]:
    """Return list of available broker keys."""
    return list(BROKER_REGISTRY.keys())
