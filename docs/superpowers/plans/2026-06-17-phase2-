pythonimport json
import logging
import re
from typing import Optional
from pydantic import BaseModel, ValidationError, Field
from llm.ollama_client import OllamaClient
from llm.claude_client import ClaudeClient

logger = logging.getLogger(__name__)

class TradeDecision(BaseModel):
    """Structured trade decision from LLM."""
    action: str = Field(..., pattern=r"^(BUY|SELL|HOLD)$")
    confidence: float = Field(ge=0.0, le=1.0)
    position_size: float = Field(ge=0.0, le=1.0)
    stop_loss: float = Field(default=-0.05)
    take_profit: float = Field(default=0.15)
    reasoning: str = ""

class LLMRouter:
    """Route LLM calls and manage response parsing."""
    
    def __init__(
        self,
        use_local_llm: bool = True,
        ollama_base_url: str = "http://localhost:11434",
        ollama_model: str = "mistral",
        claude_api_key: Optional[str] = None,
        claude_model: str = "claude-sonnet-4-6"
    ):
        """
        Args:
            use_local_llm: True for Ollama, False for Claude
            ollama_base_url: Ollama server URL
            ollama_model: Ollama model name
            claude_api_key: Claude API key (from vault)
            claude_model: Claude model name
        """
        self.use_local_llm = use_local_llm
        
        self.ollama = OllamaClient(base_url=ollama_base_url, model=ollama_model) if use_local_llm else None
        self.claude = ClaudeClient(api_key=claude_api_key, model=claude_model) if not use_local_llm and claude_api_key else None
        
        logger.info(f"LLMRouter initialized (use_local={use_local_llm})")
    
    def build_prompt(self, symbol: str, market_data: dict, context: str) -> str:
        """
        Build trading decision prompt.
        
        Args:
            symbol: Trading symbol
            market_data: Dict with price, rsi, ma20, ma50, volume, etc.
            context: Agent's context file (rules)
        
        Returns:
            Formatted prompt for LLM
        """
        
        prompt = f"""You are a trading AI. Based on the rules below and market data, decide whether to BUY, SELL, or HOLD.

TRADING RULES:
{context}

CURRENT MARKET DATA:
- Symbol: {symbol}
- Price: ${market_data.get('price', 0):.2f}
- Volume: {market_data.get('volume', 0):.0f}
- RSI(14): {market_data.get('rsi', 'N/A')}
- 20-day MA: ${market_data.get('ma20', 0):.2f}
- 50-day MA: ${market_data.get('ma50', 0):.2f}

Respond ONLY with valid JSON (no markdown, no code blocks, just raw JSON):
{{"action": "BUY|SELL|HOLD", "confidence": 0.0-1.0, "position_size": 0.0-1.0, "stop_loss": -0.05, "take_profit": 0.15, "reasoning": "brief"}}
"""
        
        return prompt
    
    def parse_decision(self, response_text: str) -> Optional[TradeDecision]:
        """
        Parse LLM response into TradeDecision.
        
        Args:
            response_text: Raw response from LLM
        
        Returns:
            TradeDecision object, or None on parse failure
        """
        
        # Extract JSON from response (may be wrapped in markdown or extra text)
        # Try raw first
        try:
            data = json.loads(response_text)
            return TradeDecision(**data)
        except (json.JSONDecodeError, ValidationError):
            pass
        
        # Try extracting JSON object with regex
        try:
            match = re.search(r'\{[^{}]*\}', response_text)
            if match:
                json_str = match.group(0)
                data = json.loads(json_str)
                return TradeDecision(**data)
        except (json.JSONDecodeError, ValidationError):
            pass
        
        logger.error(f"Failed to parse LLM response: {response_text[:100]}")
        return None
    
    async def decide(
        self,
        symbol: str,
        market_data: dict,
        context: str,
        max_retries: int = 3
    ) -> Optional[TradeDecision]:
        """
        Get trading decision from LLM with retry logic.
        
        Args:
            symbol: Trading symbol
            market_data: Market data dict
            context: Agent context file
            max_retries: Number of retries on parse failure
        
        Returns:
            TradeDecision, or TradeDecision(action=HOLD) on final failure
        """
        
        prompt = self.build_prompt(symbol, market_data, context)
        
        for attempt in range(max_retries):
            try:
                # Route to LLM
                if self.use_local_llm and self.ollama:
                    response = await self.ollama.generate(prompt)
                elif self.claude:
                    response = await self.claude.generate(prompt)
                else:
                    logger.error("No LLM configured")
                    return TradeDecision(action="HOLD", confidence=0.0)
                
                if not response:
                    logger.warning(f"LLM returned empty response (attempt {attempt + 1}/{max_retries})")
                    if attempt < max_retries - 1:
                        # Retry with clarification prompt
                        prompt += "\n\nYour previous response was invalid. Respond ONLY with valid JSON."
                        continue
                    else:
                        return TradeDecision(action="HOLD", confidence=0.0)
                
                # Parse response
                decision = self.parse_decision(response)
                if decision:
                    logger.info(f"LLM decision: {decision.action} (confidence={decision.confidence:.0%})")
                    return decision
                
                if attempt < max_retries - 1:
                    # Retry with clarification
                    prompt += "\n\nYour previous response was invalid. Respond ONLY with valid JSON."
                    continue
            
            except Exception as e:
                logger.error(f"LLM error (attempt {attempt + 1}/{max_retries}): {e}")
                if attempt == max_retries - 1:
                    break
        
        # Final fallback: return HOLD
        logger.warning(f"LLM decision failed after {max_retries} retries, returning HOLD")
        return TradeDecision(action="HOLD", confidence=0.0, reasoning="LLM timeout/error fallback")
