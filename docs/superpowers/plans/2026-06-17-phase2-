pythonimport logging

logger = logging.getLogger(__name__)

def calculate_confidence_score(
    connected_apis: int = 0,
    context_detail_score: int = 0,  # 0-10 heuristic
    wins: int = 0,
    losses: int = 0,
    consecutive_losses: int = 0
) -> int:
    """
    Calculate agent confidence score (0-100).
    
    Formula from AGENTS.md:
    score = 10  (base)
          + min(30, connected_apis * 5)
          + min(20, context_detail_score * 10)
          + min(40, (wins // 5) * 2)
          - (losses * 2)
          - (10 if consecutive_losses >= 3 else 0)
    
    Args:
        connected_apis: Number of connected data APIs (0-6)
        context_detail_score: Heuristic 0-10 for context file quality
        wins: Total winning trades
        losses: Total losing trades
        consecutive_losses: Current losing streak count
    
    Returns:
        Confidence score, clamped to 0-100
    """
    
    score = 10  # base
    
    # API quality bonus (max 30)
    api_bonus = min(30, connected_apis * 5)
    score += api_bonus
    
    # Context quality bonus (max 20)
    context_bonus = min(20, context_detail_score * 10)
    score += context_bonus
    
    # Performance bonus (max 40)
    performance_bonus = min(40, (wins // 5) * 2)
    score += performance_bonus
    
    # Loss penalties
    loss_penalty = losses * 2
    score -= loss_penalty
    
    # Consecutive loss streak penalty
    streak_penalty = 10 if consecutive_losses >= 3 else 0
    score -= streak_penalty
    
    # Clamp to 0-100
    score = max(0, min(100, score))
    
    logger.debug(
        f"Confidence calc: base=10 + api={api_bonus} + context={context_bonus} + perf={performance_bonus} - losses={loss_penalty} - streak={streak_penalty} = {score}"
    )
    
    return score
