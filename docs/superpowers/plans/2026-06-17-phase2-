pythonimport logging
from typing import Optional

logger = logging.getLogger(__name__)

class RiskManager:
    """Per-agent risk checks and auto-pause logic."""
    
    CONFIDENCE_THRESHOLD = 0.35
    MAX_CONSECUTIVE_LOSSES = 3
    
    @staticmethod
    def check_agent(
        agent_id: str,
        confidence_score: float,
        consecutive_losses: int,
        agent_drawdown: Optional[float] = None,
        max_drawdown_limit: Optional[float] = None
    ) -> tuple[bool, Optional[str]]:
        """
        Check if agent should be paused.
        
        Args:
            agent_id: Agent ID for logging
            confidence_score: 0-100 confidence
            consecutive_losses: Current losing streak
            agent_drawdown: Current agent drawdown % (negative value)
            max_drawdown_limit: Max allowed drawdown % (negative value, e.g., -0.25)
        
        Returns:
            Tuple of (should_pause: bool, reason: Optional[str])
            If should_pause=True, reason explains why
        """
        
        # Check 1: Confidence threshold
        if confidence_score < RiskManager.CONFIDENCE_THRESHOLD * 100:
            reason = f"Confidence {confidence_score:.0f}% < {RiskManager.CONFIDENCE_THRESHOLD*100:.0f}%"
            logger.warning(f"Agent {agent_id} auto-paused: {reason}")
            return True, reason
        
        # Check 2: Consecutive losses
        if consecutive_losses >= RiskManager.MAX_CONSECUTIVE_LOSSES:
            reason = f"{consecutive_losses} consecutive losses"
            logger.warning(f"Agent {agent_id} auto-paused: {reason}")
            return True, reason
        
        # Check 3: Agent-level drawdown
        if agent_drawdown is not None and max_drawdown_limit is not None:
            if agent_drawdown < max_drawdown_limit:
                reason = f"Drawdown {agent_drawdown:.2%} < limit {max_drawdown_limit:.2%}"
                logger.warning(f"Agent {agent_id} auto-paused: {reason}")
                return True, reason
        
        # All checks passed
        return False, None
