pythonimport logging
import ccxt
from typing import Optional
from brokers.base import BrokerConnector, MarketData, Order, Position

logger = logging.getLogger(__name__)

class BinanceConnector(BrokerConnector):
    """Binance crypto exchange (spot trading via ccxt)."""

    def __init__(self, api_key: str, secret: str):
        """
        Args:
            api_key: Binance API key
            secret: Binance secret key
        """
        self.exchange = ccxt.binance({
            'apiKey': api_key,
            'secret': secret,
            'enableRateLimit': True,  # CRITICAL: always enable rate limiting
        })
        logger.info("BinanceConnector initialized (ccxt.binance)")

    async def test_connection(self) -> bool:
        """Test API connectivity."""
        try:
            await self.exchange.fetch_ticker('BTC/USDT')
            return True
        except Exception as e:
            logger.error(f"Binance connection test failed: {e}")
            return False

    async def get_account_balance(self) -> float:
        """Get total account balance in USDT."""
        try:
            balance = await self.exchange.fetch_balance()
            return float(balance.get('USDT', {}).get('total', 0.0))
        except Exception as e:
            logger.error(f"Failed to get Binance balance: {e}")
            raise

    async def get_market_data(self, symbol: str) -> MarketData:
        """Fetch latest ticker + OHLCV."""
        try:
            ticker = await self.exchange.fetch_ticker(symbol)
            ohlcv = await self.exchange.fetch_ohlcv(symbol, timeframe='1m', limit=50)  # last 50 bars
            
            price = float(ticker['last'])
            volume = float(ticker['quoteVolume'])
            
            # Indicators would be computed separately
            # For MVP, we return None — orchestrator will compute via pandas-ta
            
            return MarketData(
                symbol=symbol,
                price=price,
                volume=volume,
                rsi=None,
                ma20=None,
                ma50=None,
                fetched_at=ticker['timestamp']
            )
        except Exception as e:
            logger.error(f"Failed to fetch Binance market data for {symbol}: {e}")
            raise

    async def place_order(
        self, 
        symbol: str, 
        side: str,
        quantity: float, 
        order_type: str = "market"
    ) -> Order:
        """Place market order."""
        try:
            order = await self.exchange.create_order(
                symbol=symbol,
                type=order_type.lower(),  # 'market', 'limit'
                side=side.lower(),  # 'buy', 'sell'
                amount=quantity
            )
            
            return Order(
                order_id=order['id'],
                symbol=symbol,
                side=side,
                quantity=quantity,
                filled_price=float(order.get('average', 0.0)),
                status=order['status']
            )
        except Exception as e:
            logger.error(f"Failed to place Binance order: {e}")
            raise

    async def set_stop_loss(self, order_id: str, percent: float) -> bool:
        """Set stop loss (not directly on existing orders in ccxt)."""
        logger.warning(f"Binance stop-loss requires separate order. Order: {order_id}")
        return False

    async def set_take_profit(self, order_id: str, percent: float) -> bool:
        """Set take profit (not directly on existing orders in ccxt)."""
        logger.warning(f"Binance take-profit requires separate order. Order: {order_id}")
        return False

    async def get_positions(self) -> list[Position]:
        """List open positions (spot trading, so these are asset holdings)."""
        try:
            balance = await self.exchange.fetch_balance()
            positions = []
            
            for symbol, data in balance.items():
                if data['total'] > 0:  # Non-zero holdings
                    positions.append(Position(
                        symbol=symbol,
                        quantity=data['total'],
                        avg_price=float(data.get('average', 0.0)),
                        unrealized_pnl=0.0  # For spot trading, realized only
                    ))
            
            return positions
        except Exception as e:
            logger.error(f"Failed to fetch Binance positions: {e}")
            raise

    async def close_position(self, symbol: str, quantity: Optional[float] = None) -> bool:
        """Close position (sell all or partial)."""
        try:
            if quantity:
                await self.exchange.create_order(
                    symbol=symbol,
                    type='market',
                    side='sell',
                    amount=quantity
                )
            else:
                # Sell all
                balance = await self.exchange.fetch_balance()
                base = symbol.split('/')[0]
                total = balance[base]['total']
                await self.exchange.create_order(
                    symbol=symbol,
                    type='market',
                    side='sell',
                    amount=total
                )
            return True
        except Exception as e:
            logger.error(f"Failed to close Binance position {symbol}: {e}")
            return False
