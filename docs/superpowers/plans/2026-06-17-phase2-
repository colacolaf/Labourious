pythonimport logging
import asyncio
from typing import Optional
from datetime import datetime, timedelta
from database.models import Trade
from brokers.manager import get_connector
from llm.llm_router import TradeDecision

logger = logging.getLogger(__name__)

class TradeExecutor:
    """Execute trades: position sizing, paper simulation, live orders, approval gate."""
    
    def __init__(self, vault, db_session):
        """
        Args:
            vault: EncryptedVault instance
            db_session: AsyncSession database connection
        """
        self.vault = vault
        self.db = db_session
        self.pending_approvals = {}  # {trade_id: {agent_id, decision, timeout_at}}
    
    def calculate_position_size(
        self,
        agent_capital_allocation: float,
        account_balance: float,
        decision_position_size: float,
        max_position_size_percent: float = 0.05
    ) -> float:
        """
        Calculate actual position size.
        
        Args:
            agent_capital_allocation: Agent's allocated capital %
            account_balance: Current account balance
            decision_position_size: LLM decision position size (0-1)
            max_position_size_percent: Max per trade (default 5%)
        
        Returns:
            Dollar amount to trade
        """
        
        agent_capital = account_balance * agent_capital_allocation
        position_size = agent_capital * decision_position_size
        max_position = account_balance * max_position_size_percent
        
        position_size = min(position_size, max_position)
        
        logger.debug(f"Position sizing: capital={agent_capital:.0f}, decision={decision_position_size:.0%}, max={max_position:.0f} → result={position_size:.0f}")
        
        return position_size
    
    async def execute(
        self,
        agent_id: str,
        decision: TradeDecision,
        agent_config: dict,
        vault,
        db_session,
        approval_callback = None
    ) -> dict:
        """
        Execute trade: paper sim OR live order.
        
        Args:
            agent_id: Agent ID
            decision: LLM TradeDecision
            agent_config: Agent configuration dict
            vault: EncryptedVault
            db_session: Database session
            approval_callback: Optional async callback for approval notification
        
        Returns:
            Execution result dict
        """
        
        # Skip HOLD
        if decision.action == "HOLD":
            return {"status": "skipped", "reason": "HOLD decision"}
        
        # Get connector
        connector = get_connector(
            agent_config.get('broker', 'alpaca'),
            vault,
            is_paper=agent_config.get('paper_trading', True)
        )
        
        if not connector:
            return {"status": "error", "reason": "Failed to connect to broker"}
        
        # Get account balance
        try:
            account_balance = await connector.get_account_balance()
        except Exception as e:
            logger.error(f"Failed to get account balance: {e}")
            return {"status": "error", "reason": "Account balance check failed"}
        
        # Calculate position size
        position_size_dollars = self.calculate_position_size(
            agent_capital_allocation=agent_config.get('allocation_percent', 0.1),
            account_balance=account_balance,
            decision_position_size=decision.position_size,
            max_position_size_percent=agent_config.get('max_position_size', 0.05)
        )
        
        symbol = agent_config.get('asset', 'AAPL')
        quantity = position_size_dollars / decision.position_size if decision.position_size > 0 else 0
        
        # Check execution mode
        execution_mode = agent_config.get('execution_mode', 'human_in_loop')
        
        if execution_mode == 'autonomous':
            # Execute immediately
            return await self._execute_live_order(
                agent_id, symbol, decision.action, quantity, connector, db_session
            )
        
        elif execution_mode == 'human_in_loop':
            # Store for approval and notify user
            trade_id = f"trade_{agent_id}_{int(datetime.now().timestamp())}"
            timeout_at = datetime.now() + timedelta(seconds=30)
            
            self.pending_approvals[trade_id] = {
                "agent_id": agent_id,
                "decision": decision,
                "timeout_at": timeout_at
            }
            
            if approval_callback:
                await approval_callback({
                    "type": "agent_approval_needed",
                    "trade_id": trade_id,
                    "agent_id": agent_id,
                    "symbol": symbol,
                    "side": decision.action,
                    "quantity": quantity,
                    "reasoning": decision.reasoning
                })
            
            # Start background task to auto-reject on timeout
            asyncio.create_task(self._approval_timeout(trade_id))
            
            return {"status": "pending_approval", "trade_id": trade_id, "timeout_seconds": 30}
        
        else:
            return {"status": "unknown_execution_mode"}
    
    async def approve_trade(self, trade_id: str, approved: bool) -> dict:
        """
        User approval callback.
        
        Args:
            trade_id: Trade ID
            approved: True to execute, False to reject
        
        Returns:
            Execution result
        """
        
        if trade_id not in self.pending_approvals:
            return {"status": "error", "reason": "Trade not found"}
        
        approval = self.pending_approvals.pop(trade_id)
        
        if not approved:
            logger.info(f"Trade {trade_id} rejected by user")
            return {"status": "rejected", "trade_id": trade_id}
        
        # Execute
        agent_id = approval['agent_id']
        decision = approval['decision']
        
        # TODO: fetch connector + execute_live_order
        logger.info(f"Trade {trade_id} approved, executing...")
        
        return {"status": "approved_executed", "trade_id": trade_id}
    
    async def _execute_live_order(
        self,
        agent_id: str,
        symbol: str,
        side: str,
        quantity: float,
        connector,
        db_session
    ) -> dict:
        """Execute live order via broker."""
        
        try:
            order = await connector.place_order(symbol, side, quantity, order_type="market")
            
            # Log to DB
            trade = Trade(
                id=f"trade_{agent_id}_{int(datetime.now().timestamp())}",
                agent_id=agent_id,
                symbol=symbol,
                side=side,
                quantity=quantity,
                entry_price=order.filled_price or 0.0,
                entry_time=datetime.now(),
                status='filled'
            )
            db_session.add(trade)
            await db_session.commit()
            
            logger.info(f"Trade executed: {symbol} {side} {quantity} @ {order.filled_price}")
            
            return {
                "status": "executed",
                "order_id": order.order_id,
                "symbol": symbol,
                "side": side,
                "quantity": quantity,
                "filled_price": order.filled_price
            }
        
        except Exception as e:
            logger.error(f"Order execution failed: {e}")
            return {"status": "error", "reason": str(e)}
    
    async def _approval_timeout(self, trade_id: str):
        """Auto-reject trade after timeout."""
        
        approval = self.pending_approvals.get(trade_id)
        if not approval:
            return
        
        timeout_at = approval['timeout_at']
        delay_seconds = (timeout_at - datetime.now()).total_seconds()
        
        if delay_seconds > 0:
            await asyncio.sleep(delay_seconds)
        
        if trade_id in self.pending_approvals:
            logger.warning(f"Trade {trade_id} auto-rejected (timeout)")
            self.pending_approvals.pop(trade_id)
