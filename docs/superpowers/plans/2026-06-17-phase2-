pythonfrom abc import ABC, abstractmethod
from dataclasses import dataclass
from typing import Optional

@dataclass
class MarketData:
    """Live market snapshot for a symbol."""
    symbol: str
    price: float
    volume: float
    rsi: Optional[float] = None
    ma20: Optional[float] = None
    ma50: Optional[float] = None
    fetched_at: float = 0.0  # unix timestamp

@dataclass
class Order:
    """Order execution result."""
    order_id: str
    symbol: str
    side: str  # BUY or SELL
    quantity: float
    filled_price: Optional[float]
    status: str  # pending, filled, failed

@dataclass
class Position:
    """Open position snapshot."""
    symbol: str
    quantity: float
    avg_price: float
    unrealized_pnl: float

class BrokerConnector(ABC):
    """Abstract base for all broker integrations."""

    @abstractmethod
    async def test_connection(self) -> bool:
        """Test API connectivity. Return True if successful."""
        pass

    @abstractmethod
    async def get_account_balance(self) -> float:
        """Fetch current account balance in primary currency (USD or equivalent)."""
        pass

    @abstractmethod
    async def get_market_data(self, symbol: str) -> MarketData:
        """Fetch live market data for symbol."""
        pass

    @abstractmethod
    async def place_order(
        self, 
        symbol: str, 
        side: str,  # BUY or SELL
        quantity: float, 
        order_type: str = "market"  # market, limit, stop
    ) -> Order:
        """Place order. Return Order with order_id."""
        pass

    @abstractmethod
    async def set_stop_loss(self, order_id: str, percent: float) -> bool:
        """Set stop loss on order. Percent is negative (e.g., -0.05 for 5% stop)."""
        pass

    @abstractmethod
    async def set_take_profit(self, order_id: str, percent: float) -> bool:
        """Set take profit on order. Percent is positive (e.g., 0.15 for 15% target)."""
        pass

    @abstractmethod
    async def get_positions(self) -> list[Position]:
        """List all open positions."""
        pass

    @abstractmethod
    async def close_position(self, symbol: str, quantity: Optional[float] = None) -> bool:
        """Close position (or partial). Return True if successful."""
        pass
