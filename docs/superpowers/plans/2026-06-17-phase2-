pythonimport logging
from typing import Optional
from alpaca_trade_api import REST as AlpacaAPI
from brokers.base import BrokerConnector, MarketData, Order, Position

logger = logging.getLogger(__name__)

class AlpacaConnector(BrokerConnector):
    """Alpaca stock broker (paper + live)."""

    def __init__(self, api_key: str, secret: str, is_paper: bool = True):
        """
        Args:
            api_key: Alpaca API key
            secret: Alpaca secret key
            is_paper: True for paper trading, False for live
        """
        base_url = "https://paper-api.alpaca.markets" if is_paper else "https://api.alpaca.markets"
        self.api = AlpacaAPI(api_key=api_key, secret_key=secret, base_url=base_url)
        self.is_paper = is_paper
        logger.info(f"AlpacaConnector initialized (mode={'paper' if is_paper else 'live'})")

    async def test_connection(self) -> bool:
        """Test API connectivity."""
        try:
            account = self.api.get_account()
            return account.status == 'active'
        except Exception as e:
            logger.error(f"Alpaca connection test failed: {e}")
            return False

    async def get_account_balance(self) -> float:
        """Get account equity."""
        try:
            account = self.api.get_account()
            return float(account.equity)
        except Exception as e:
            logger.error(f"Failed to get Alpaca balance: {e}")
            raise

    async def get_market_data(self, symbol: str) -> MarketData:
        """Fetch latest bar + quote."""
        try:
            bar = self.api.get_latest_bar(symbol)
            quote = self.api.get_latest_quote(symbol)
            price = float(bar.c)
            volume = float(bar.v)
            
            # Indicators would be computed separately (not from Alpaca API in Phase 2)
            # For MVP, we return None — orchestrator will compute via pandas-ta
            
            return MarketData(
                symbol=symbol,
                price=price,
                volume=volume,
                rsi=None,
                ma20=None,
                ma50=None,
                fetched_at=int(bar.t.timestamp())
            )
        except Exception as e:
            logger.error(f"Failed to fetch Alpaca market data for {symbol}: {e}")
            raise

    async def place_order(
        self, 
        symbol: str, 
        side: str,
        quantity: float, 
        order_type: str = "market"
    ) -> Order:
        """Place market or limit order."""
        try:
            order = self.api.submit_order(
                symbol=symbol,
                qty=quantity,
                side=side.lower(),  # 'buy' or 'sell'
                type=order_type,
                time_in_force='day'
            )
            
            filled_price = float(order.filled_avg_price) if order.filled_avg_price else None
            
            return Order(
                order_id=order.id,
                symbol=symbol,
                side=side,
                quantity=quantity,
                filled_price=filled_price,
                status=order.status
            )
        except Exception as e:
            logger.error(f"Failed to place Alpaca order: {e}")
            raise

    async def set_stop_loss(self, order_id: str, percent: float) -> bool:
        """Set stop loss via TrailingStop (Alpaca limitation)."""
        try:
            # Alpaca doesn't support direct stop-loss edits; use trailing stop instead
            # For MVP, we just log that this is a limitation
            logger.warning(f"Alpaca doesn't support per-order stop-loss. Order: {order_id}")
            return False
        except Exception as e:
            logger.error(f"Failed to set Alpaca stop loss: {e}")
            return False

    async def set_take_profit(self, order_id: str, percent: float) -> bool:
        """Set take profit (not directly supported by Alpaca)."""
        try:
            logger.warning(f"Alpaca doesn't support per-order take-profit. Order: {order_id}")
            return False
        except Exception as e:
            logger.error(f"Failed to set Alpaca take profit: {e}")
            return False

    async def get_positions(self) -> list[Position]:
        """List open positions."""
        try:
            positions = self.api.list_positions()
            result = []
            for pos in positions:
                result.append(Position(
                    symbol=pos.symbol,
                    quantity=float(pos.qty),
                    avg_price=float(pos.avg_fill_price),
                    unrealized_pnl=float(pos.unrealized_pl)
                ))
            return result
        except Exception as e:
            logger.error(f"Failed to fetch Alpaca positions: {e}")
            raise

    async def close_position(self, symbol: str, quantity: Optional[float] = None) -> bool:
        """Close position entirely or partially."""
        try:
            if quantity:
                self.api.submit_order(
                    symbol=symbol,
                    qty=quantity,
                    side='sell',
                    type='market',
                    time_in_force='day'
                )
            else:
                self.api.close_position(symbol)
            return True
        except Exception as e:
            logger.error(f"Failed to close Alpaca position {symbol}: {e}")
            return False
