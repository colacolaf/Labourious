python"""
LLM cost estimation for different providers.
"""

# Per-output-token pricing (USD)
PRICES_PER_TOKEN = {
    "ollama": 0.0,
    "claude": 0.000003,    # claude-sonnet-4-6
    "openai": 0.000010,    # gpt-4o
}

# Average tokens per LLM decision call
TOKENS_PER_CALL = 800  # ~600 prompt tokens + ~200 response tokens


def estimate_monthly_cost(
    provider: str,
    check_frequency_seconds: int
) -> float:
    """
    Estimate monthly LLM cost for an agent.
    
    Args:
        provider: 'ollama', 'claude', or 'openai'
        check_frequency_seconds: Seconds between agent checks
    
    Returns:
        Estimated monthly cost in USD
    """
    if provider not in PRICES_PER_TOKEN:
        return 0.0
    
    price_per_token = PRICES_PER_TOKEN[provider]
    
    if price_per_token == 0.0:
        return 0.0
    
    # Calculate calls per month
    seconds_per_day = 86400
    seconds_per_month = seconds_per_day * 30
    
    calls_per_month = seconds_per_month / check_frequency_seconds
    
    # Calculate total cost
    total_tokens = calls_per_month * TOKENS_PER_CALL
    monthly_cost = total_tokens * price_per_token
    
    return round(monthly_cost, 2)
