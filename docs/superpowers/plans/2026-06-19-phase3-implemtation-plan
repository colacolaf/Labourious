python@router.post("/{agent_id}/llm-provider")
async def update_agent_llm_provider(
    agent_id: str,
    provider_data: dict,
    db: Session = Depends(get_db)
):
    """Update agent's LLM provider"""
    agent = db.query(Agent).filter_by(id=agent_id).first()
    if not agent:
        raise HTTPException(status_code=404, detail="Agent not found")
    
    provider = provider_data.get('provider', 'ollama')
    if provider not in ['ollama', 'claude', 'openai']:
        raise HTTPException(status_code=400, detail="Invalid LLM provider")
    
    agent.llm_provider = provider
    db.commit()
    
    return {"status": "updated", "provider": provider}
