def test_compute_correlation_matrix_basic():
    """Test pairwise correlation calculation"""
    returns = {
        'agent_a': [0.01, 0.02, -0.01, 0.015, 0.005] * 6,  # 30 values
        'agent_b': [0.02, 0.03, -0.02, 0.020, 0.010] * 6,  # Similar pattern
        'agent_c': [-0.01, -0.02, 0.01, -0.015, -0.005] * 6,  # Inverse pattern
    }
    corr = compute_correlation_matrix(returns)
    
    # Diagonal should be 1.0
    assert abs(corr['agent_a']['agent_a'] - 1.0) < 0.001
    assert abs(corr['agent_b']['agent_b'] - 1.0) < 0.001
    assert abs(corr['agent_c']['agent_c'] - 1.0) < 0.001
    
    # agent_a and agent_b should be highly correlated (similar pattern)
    assert corr['agent_a']['agent_b'] > 0.8
    
    # agent_a and agent_c should be negatively correlated (inverse)
    assert corr['agent_a']['agent_c'] < -0.8
    
    # Symmetry
    assert corr['agent_a']['agent_b'] == corr['agent_b']['agent_a']

