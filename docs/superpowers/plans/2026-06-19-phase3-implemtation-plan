    sort_by: str = "return",
    limit: int = 20,
    db: Session = Depends(get_db)
):
    """
    GET /api/analytics/leaderboard?sort_by=return&limit=20
    
    Returns ranked agents by metric (return, sharpe, win_rate).
    sort_by: 'return', 'sharpe', 'win_rate'
    """
    try:
        today = date.today()
        
        # Get today's snapshots
        snapshots = db.query(DailySnapshot).filter(
            DailySnapshot.snapshot_date == today
        ).all()
        
        # Load agent names
        agent_data = []
        for snapshot in snapshots:
            agent = db.query(Agent).filter_by(id=snapshot.agent_id).first()
            if agent:
                agent_data.append({
                    "agent_id": snapshot.agent_id,
                    "name": agent.name,
                    "return_pct": snapshot.daily_return_pct,
                    "sharpe": snapshot.sharpe_ratio or 0.0,
                    "win_rate": (snapshot.win_rate or 0.0) * 100,  # Convert to %
                    "trade_count": snapshot.trade_count,
                    "status": "✅" if agent.enabled else "⏸"
                })
        
        # Sort
        if sort_by == "sharpe":
            agent_data.sort(key=lambda x: x["sharpe"], reverse=True)
        elif sort_by == "win_rate":
            agent_data.sort(key=lambda x: x["win_rate"], reverse=True)
        else:  # Default: return
            agent_data.sort(key=lambda x: x["return_pct"], reverse=True)
        
        return {"leaderboard": agent_data[:limit]}
    
    except Exception as e:
        logger.error(f"Error fetching leaderboard: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="Failed to compute leaderboard")


@router.get("/correlation")
async def get_correlation(db: Session = Depends(get_db)):
    """
    GET /api/analytics/correlation
    
    Returns pairwise correlation matrix between agents (30-day).
    """
    try:
        # Get agents' daily returns (last 30 days)
        thirty_days_ago = date.today() - timedelta(days=30)
        snapshots = db.query(DailySnapshot).filter(
            DailySnapshot.snapshot_date >= thirty_days_ago
        ).order_by(DailySnapshot.snapshot_date).all()
        
        # Build agents_daily_returns dict
        agents_returns = {}
        for snapshot in snapshots:
            if snapshot.agent_id not in agents_returns:
                agents_returns[snapshot.agent_id] = []
            agents_returns[snapshot.agent_id].append(snapshot.daily_return_pct / 100)
        
        # Compute correlation
        corr_matrix = compute_correlation_matrix(agents_returns)
        
        return {"matrix": corr_matrix}
    
    except Exception as e:
        logger.error(f"Error computing correlation: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="Failed to compute correlation")


@router.get("/attribution")
async def get_attribution(
    date_str: Optional[str] = None,
    db: Session = Depends(get_db)
):
    """
    GET /api/analytics/attribution?date=2026-06-19
    
    Returns P&L attribution by agent for given date.
    Defaults to today.
    """
    try:
        if not date_str:
            target_date = date.today().isoformat()
        else:
            target_date = date_str  # Assume YYYY-MM-DD format
        
        # Query trades for that date
        trades = db.query(Trade).filter(
            Trade.status == "closed",
            Trade.exit_time >= datetime.fromisoformat(f"{target_date}T00:00:00"),
            Trade.exit_time < datetime.fromisoformat(f"{target_date}T23:59:59")
        ).all()
        
        # Convert to trade dicts for attribution function
        trade_dicts = [
            {
                "agent_id": t.agent_id,
                "pnl": t.p_and_l or 0.0,
                "closed_at": t.exit_time.isoformat()
            }
            for t in trades
        ]
        
        # Compute attribution
        attribution = compute_attribution(trade_dicts, target_date)
        
        # Load agent names
        result = {}
        for agent_id, attr in attribution.items():
            agent = db.query(Agent).filter_by(id=agent_id).first()
            agent_name = agent.name if agent else agent_id
            result[agent_name] = {
                "pnl": attr["pnl"],
                "pct": attr["pct"]
            }
        
        return {"attribution": result}
    
    except Exception as e:
        logger.error(f"Error computing attribution: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="Failed to compute attribution")
