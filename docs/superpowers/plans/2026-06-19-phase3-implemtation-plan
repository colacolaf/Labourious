python"""
Pure metrics computation functions for analytics.
No database dependencies; accepts lists/dicts only.
"""

from typing import Dict, List, Optional
import numpy as np
from datetime import datetime


def compute_sharpe(
    daily_returns: List[float],
    risk_free_rate: float = 0.0
) -> float:
    """
    Calculate annualized Sharpe ratio.
    
    Args:
        daily_returns: List of daily return percentages (e.g., [0.01, 0.02, -0.01])
        risk_free_rate: Annual risk-free rate (default 0.0)
    
    Returns:
        Annualized Sharpe ratio, or 0.0 if insufficient data
    """
    if not daily_returns or len(daily_returns) < 2:
        return 0.0
    
    returns_array = np.array(daily_returns)
    
    mean_return = np.mean(returns_array)
    std_return = np.std(returns_array)
    
    # Avoid division by zero
    if std_return == 0.0:
        return 0.0
    
    # Annualize: daily -> annual (252 trading days)
    annual_return = mean_return * 252
    annual_std = std_return * np.sqrt(252)
    
    sharpe = (annual_return - risk_free_rate) / annual_std
    return float(sharpe)


def compute_max_drawdown(equity_curve: List[float]) -> float:
    """
    Calculate maximum drawdown as percentage.
    
    Args:
        equity_curve: List of account values [100, 105, 110, 95, ...]
    
    Returns:
        Max drawdown as decimal (e.g., -0.083 for -8.3%), or 0.0 if no drawdown
    """
    if not equity_curve or len(equity_curve) < 2:
        return 0.0
    
    equity_array = np.array(equity_curve)
    
    # Compute running maximum
    running_max = np.maximum.accumulate(equity_array)
    
    # Drawdown = (current - peak) / peak
    drawdowns = (equity_array - running_max) / running_max
    
    max_dd = np.min(drawdowns)  # Most negative value
    return float(max_dd)


def compute_correlation_matrix(
    agents_daily_returns: Dict[str, List[float]]
) -> Dict[str, Dict[str, float]]:
    """
    Compute pairwise Pearson correlation between agents.
    
    Args:
        agents_daily_returns: {agent_id: [daily returns]}
    
    Returns:
        {agent_a: {agent_b: correlation_coefficient}}
        Diagonal = 1.0, off-diagonal = Pearson r
    """
    if len(agents_daily_returns) < 1:
        return {}
    
    agent_ids = list(agents_daily_returns.keys())
    
    # Convert to matrix (agents x days)
    returns_matrix = np.array([
        agents_daily_returns[agent_id]
        for agent_id in agent_ids
    ])
    
    # Compute correlation matrix
    corr_matrix = np.corrcoef(returns_matrix)
    
    # Convert to dict
    result = {}
    for i, agent_a in enumerate(agent_ids):
        result[agent_a] = {}
        for j, agent_b in enumerate(agent_ids):
            # Handle NaN from corrcoef (e.g., zero variance)
            corr_value = corr_matrix[i, j]
            if np.isnan(corr_value):
                corr_value = 0.0
            result[agent_a][agent_b] = float(corr_value)
    
    return result


def compute_attribution(
    trades: List[Dict],
    date_str: str
) -> Dict[str, Dict[str, float]]:
    """
    Compute P&L attribution by agent for a given date.
    
    Args:
        trades: List of trade dicts with keys: agent_id, pnl, closed_at
        date_str: Date string in format 'YYYY-MM-DD' (e.g., '2026-06-19')
    
    Returns:
        {agent_id: {'pnl': float, 'pct': float}}
        pnl = total P&L for that agent that day
        pct = share of day's total P&L
    """
    attribution = {}
    total_pnl = 0.0
    
    # Filter trades by date
    for trade in trades:
        closed_at_str = trade['closed_at']  # Format: '2026-06-19T10:15:00'
        trade_date = closed_at_str.split('T')[0]  # Extract date part
        
        if trade_date == date_str:
            agent_id = trade['agent_id']
            pnl = trade['pnl']
            
            if agent_id not in attribution:
                attribution[agent_id] = {'pnl': 0.0}
            
            attribution[agent_id]['pnl'] += pnl
            total_pnl += pnl
    
    # Compute percentages
    if total_pnl != 0.0:
        for agent_id in attribution:
            attribution[agent_id]['pct'] = attribution[agent_id]['pnl'] / total_pnl
    else:
        for agent_id in attribution:
            attribution[agent_id]['pct'] = 0.0
    
    return attribution
