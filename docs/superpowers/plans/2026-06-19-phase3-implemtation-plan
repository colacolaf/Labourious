python"""
EOD (End of Day) snapshot job — computes daily metrics for each agent.
Runs via APScheduler at 16:05 EST daily.
"""

import logging
from datetime import date, datetime
from typing import Optional
from sqlalchemy.orm import Session
from sqlalchemy import and_

from backend.database.models import Agent, Trade, DailySnapshot
from backend.analytics.metrics import compute_sharpe, compute_max_drawdown

logger = logging.getLogger(__name__)


async def run_eod_snapshot(session: Session) -> None:
    """
    Compute and store daily snapshot for all active agents.
    
    For each agent:
    1. Query trades closed today
    2. Compute daily P&L, win rate, trade count
    3. Compute Sharpe and max drawdown (30-day lookback)
    4. Upsert one DailySnapshot row per agent
    
    Args:
        session: SQLAlchemy session (can be async or sync)
    """
    try:
        logger.info("EOD snapshot job started")
        
        today = date.today()
        agents = session.query(Agent).filter_by(enabled=True).all()
        
        for agent in agents:
            # Query trades closed today
            today_trades = session.query(Trade).filter(
                and_(
                    Trade.agent_id == agent.id,
                    Trade.status == "closed",
                    Trade.exit_time >= datetime.combine(today, datetime.min.time()),
                    Trade.exit_time < datetime.combine(today + timedelta(days=1), datetime.min.time())
                )
            ).all()
            
            if not today_trades:
                # No trades today, skip
                logger.debug(f"No trades for {agent.name} today")
                continue
            
            # Compute today's metrics
            total_pnl = sum([t.p_and_l for t in today_trades if t.p_and_l is not None])
            trade_count = len(today_trades)
            winning_trades = sum([1 for t in today_trades if (t.p_and_l or 0) > 0])
            win_rate = winning_trades / trade_count if trade_count > 0 else 0.0
            
            # Daily return percentage
            # Rough estimate: use first trade's entry as base
            if today_trades and today_trades[0].entry_price:
                daily_return_pct = (total_pnl / today_trades[0].entry_price) * 100
            else:
                daily_return_pct = 0.0
            
            # Compute Sharpe and max drawdown (30-day lookback)
            last_30_days_snapshots = session.query(DailySnapshot).filter(
                DailySnapshot.agent_id == agent.id,
                DailySnapshot.snapshot_date >= today - timedelta(days=30)
            ).all()
            
            if last_30_days_snapshots:
                daily_returns = [s.daily_return_pct / 100 for s in last_30_days_snapshots]
                sharpe = compute_sharpe(daily_returns)
                
                # Compute equity curve for max drawdown
                equity = [100.0]  # Start at 100
                for snapshot in sorted(last_30_days_snapshots, key=lambda s: s.snapshot_date):
                    equity.append(equity[-1] * (1 + snapshot.daily_return_pct / 100))
                max_dd = compute_max_drawdown(equity)
            else:
                sharpe = 0.0
                max_dd = 0.0
            
            # Upsert snapshot
            existing = session.query(DailySnapshot).filter(
                and_(
                    DailySnapshot.agent_id == agent.id,
                    DailySnapshot.snapshot_date == today
                )
            ).first()
            
            if existing:
                # Update
                existing.total_pnl = total_pnl
                existing.daily_return_pct = daily_return_pct
                existing.sharpe_ratio = sharpe
                existing.max_drawdown = max_dd
                existing.win_rate = win_rate
                existing.trade_count = trade_count
            else:
                # Create
                snapshot = DailySnapshot(
                    agent_id=agent.id,
                    snapshot_date=today,
                    total_pnl=total_pnl,
                    daily_return_pct=daily_return_pct,
                    sharpe_ratio=sharpe,
                    max_drawdown=max_dd,
                    win_rate=win_rate,
                    trade_count=trade_count
                )
                session.add(snapshot)
            
            logger.info(f"Snapshot for {agent.name}: P&L={total_pnl}, trades={trade_count}, win={win_rate*100:.1f}%")
        
        session.commit()
        logger.info("EOD snapshot job completed successfully")
    
    except Exception as e:
        logger.error(f"EOD snapshot job failed: {e}", exc_info=True)
        session.rollback()
        raise


async def schedule_eod_snapshot_job(scheduler, session_factory):
    """
    Register EOD snapshot job with APScheduler.
    
    Fires at 16:05 EST daily (market close + 5 min buffer).
    
    Args:
        scheduler: APScheduler AsyncScheduler instance
        session_factory: SQLAlchemy session factory
    """
    from apscheduler.triggers.cron import CronTrigger
    
    async def job_wrapper():
        session = session_factory()
        try:
            await run_eod_snapshot(session)
        finally:
            session.close()
    
    trigger = CronTrigger(hour=16, minute=5, timezone="US/Eastern")
    scheduler.add_job(job_wrapper, trigger=trigger, id="eod_snapshot_job")
    logger.info("EOD snapshot job scheduled for 16:05 EST daily")
