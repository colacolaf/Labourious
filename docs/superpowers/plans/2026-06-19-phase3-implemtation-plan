@router.get("/portfolio")
async def get_portfolio_summary(db: Session = Depends(get_db)):
    """
    GET /api/analytics/portfolio
    
    Returns portfolio-wide metrics (all agents combined).
    """
    try:
        today = date.today()
        
        # Sum all P&L from today's snapshots
        today_snapshots = db.query(DailySnapshot).filter(
            DailySnapshot.snapshot_date == today
        ).all()
        
        total_pnl = sum([s.total_pnl for s in today_snapshots])
        
        # Average Sharpe across agents (rough estimate)
        sharpe_values = [s.sharpe_ratio for s in today_snapshots if s.sharpe_ratio is not None]
        avg_sharpe = sum(sharpe_values) / len(sharpe_values) if sharpe_values else 0.0
        
        # Worst max drawdown
        max_dd = min([s.max_drawdown for s in today_snapshots if s.max_drawdown is not None], default=0.0)
        
        # 30-day return
        thirty_days_ago = today - timedelta(days=30)
        thirty_day_snapshots = db.query(DailySnapshot).filter(
            DailySnapshot.snapshot_date >= thirty_days_ago
        ).all()
        return_30d = sum([s.daily_return_pct for s in thirty_day_snapshots]) / 30 if thirty_day_snapshots else 0.0
        
        # YTD return (Jan 1 to today)
        ytd_snapshots = db.query(DailySnapshot).filter(
            DailySnapshot.snapshot_date >= date(today.year, 1, 1)
        ).all()
        return_ytd = sum([s.daily_return_pct for s in ytd_snapshots]) / len(ytd_snapshots) if ytd_snapshots else 0.0
        
        return {
            "total_pnl": total_pnl,
            "return_30d": return_30d,
            "return_ytd": return_ytd,
            "sharpe_ratio": avg_sharpe,
            "max_drawdown": max_dd
        }
    
    except Exception as e:
        logger.error(f"Error fetching portfolio summary: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="Failed to compute portfolio summary")


@router.get("/equity-curve")
async def get_equity_curve(
    days: int = 30,
    agent_id: str = "all",
    db: Session = Depends(get_db)
):
    """
    GET /api/analytics/equity-curve?days=30&agent_id=all
    
    Returns daily equity curve for past N days.
    If agent_id='all', combines all agents.
    """
    try:
        cutoff_date = date.today() - timedelta(days=days)
        
        if agent_id == "all":
            snapshots = db.query(DailySnapshot).filter(
                DailySnapshot.snapshot_date >= cutoff_date
            ).order_by(DailySnapshot.snapshot_date).all()
        else:
            snapshots = db.query(DailySnapshot).filter(
                DailySnapshot.agent_id == agent_id,
                DailySnapshot.snapshot_date >= cutoff_date
            ).order_by(DailySnapshot.snapshot_date).all()
        
        # Build equity curve (starting at 100)
        equity = 100.0
        equity_curve = []
        
        for snapshot in snapshots:
            equity *= (1 + snapshot.daily_return_pct / 100)
            equity_curve.append({
                "date": snapshot.snapshot_date.isoformat(),
                "value": round(equity, 2)
            })
        
        return {"equity_curve": equity_curve}
    
    except Exception as e:
        logger.error(f"Error fetching equity curve: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail="Failed to compute equity curve")


