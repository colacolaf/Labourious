python"""
Backtest runner — orchestrates backtesting via subprocess.
Manages BacktestResult rows and polling.
"""

import logging
import uuid
import asyncio
import subprocess
from datetime import date
from typing import Dict, Optional
from sqlalchemy.orm import Session
from backend.database.models import Agent, BacktestResult

logger = logging.getLogger(__name__)

# In-memory cache of running backtest processes
BACKTEST_PROCESSES: Dict[str, asyncio.Task] = {}


async def submit_backtest(
    session: Session,
    agent_id: str,
    start_date: str,
    end_date: str,
    mode: str
) -> str:
    """
    Submit a backtest run (async).
    
    Args:
        session: SQLAlchemy session
        agent_id: Agent to backtest
        start_date: 'YYYY-MM-DD'
        end_date: 'YYYY-MM-DD'
        mode: 'basic' or 'walk_forward'
    
    Returns:
        run_id (UUID)
    
    Raises:
        ValueError: If date validation fails
    """
    # Validate dates
    start = date.fromisoformat(start_date)
    end = date.fromisoformat(end_date)
    
    if start > end:
        raise ValueError("start_date must be before end_date")
    if (end - start).days < 1:
        raise ValueError("backtest must span at least 1 day")
    
    # Verify agent exists
    agent = session.query(Agent).filter_by(id=agent_id).first()
    if not agent:
        raise ValueError(f"Agent {agent_id} not found")
    
    # Create BacktestResult row
    run_id = str(uuid.uuid4())
    result = BacktestResult(
        id=run_id,
        agent_id=agent_id,
        start_date=start,
        end_date=end,
        mode=mode,
        status="running",
        result_json={}
    )
    session.add(result)
    session.commit()
    
    # Spawn backtest subprocess
    task = asyncio.create_task(
        _run_backtest_subprocess(run_id, agent_id, start_date, end_date, mode, session)
    )
    BACKTEST_PROCESSES[run_id] = task
    
    logger.info(f"Backtest {run_id} submitted for agent {agent_id}")
    return run_id


async def _run_backtest_subprocess(
    run_id: str,
    agent_id: str,
    start_date: str,
    end_date: str,
    mode: str,
    session: Session
) -> None:
    """
    Run backtest via subprocess (python -m backend.scripts.backtest).
    Update BacktestResult when done.
    """
    try:
        cmd = [
            "python", "-m", "backend.scripts.backtest",
            "--agent_id", agent_id,
            "--start_date", start_date,
            "--end_date", end_date,
            "--mode", mode,
            "--output_json"
        ]
        
        process = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        
        stdout, stderr = await process.communicate()
        
        if process.returncode == 0:
            import json
            result_json = json.loads(stdout.decode())
            
            # Update row
            result = session.query(BacktestResult).filter_by(id=run_id).first()
            if result:
                result.status = "done"
                result.result_json = result_json
                session.commit()
            
            logger.info(f"Backtest {run_id} completed successfully")
        else:
            error_msg = stderr.decode()
            result = session.query(BacktestResult).filter_by(id=run_id).first()
            if result:
                result.status = "failed"
                result.error_message = error_msg
                session.commit()
            
            logger.error(f"Backtest {run_id} failed: {error_msg}")
    
    except Exception as e:
        logger.error(f"Backtest {run_id} exception: {e}", exc_info=True)
        result = session.query(BacktestResult).filter_by(id=run_id).first()
        if result:
            result.status = "failed"
            result.error_message = str(e)
            session.commit()


def get_backtest_status(
    session: Session,
    run_id: str
) -> Dict:
    """Get backtest status (poll-friendly)"""
    result = session.query(BacktestResult).filter_by(id=run_id).first()
    if not result:
        return {"status": "not_found"}
    
    return {
        "run_id": run_id,
        "status": result.status,
        "result": result.result_json if result.status == "done" else None,
        "error": result.error_message if result.status == "failed" else None
    }


def get_backtest_history(
    session: Session,
    agent_id: str,
    limit: int = 20
) -> list:
    """Get past backtest runs for agent"""
    results = session.query(BacktestResult).filter_by(
        agent_id=agent_id
    ).order_by(BacktestResult.run_at.desc()).limit(limit).all()
    
    return [
        {
            "run_id": r.id,
            "start_date": r.start_date.isoformat(),
            "end_date": r.end_date.isoformat(),
            "mode": r.mode,
            "status": r.status,
            "run_at": r.run_at.isoformat()
        }
        for r in results
    ]
