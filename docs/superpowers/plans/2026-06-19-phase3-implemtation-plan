javascript/**
 * Estimate monthly LLM cost for an agent
 */

const PRICES_PER_TOKEN = {
  ollama: 0.0,
  claude: 0.000003,
  openai: 0.000010
};

const TOKENS_PER_CALL = 800;

export function estimateLlmCost(provider, checkFrequencySeconds) {
  const pricePerToken = PRICES_PER_TOKEN[provider] || 0;
  
  if (pricePerToken === 0) {
    return 0;
  }
  
  const secondsPerDay = 86400;
  const secondsPerMonth = secondsPerDay * 30;
  const callsPerMonth = secondsPerMonth / checkFrequencySeconds;
  const totalTokens = callsPerMonth * TOKENS_PER_CALL;
  const monthlyCost = totalTokens * pricePerToken;
  
  return Math.round(monthlyCost * 100) / 100; // 2 decimals
}
