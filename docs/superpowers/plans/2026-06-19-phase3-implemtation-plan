                    self._openai = OpenAIClient(api_key=openai_key, model="gpt-4o")
            except:
                pass  # API key not set, OpenAI unavailable
    
    async def decide(self, market_data, context, agent):
        """Route to appropriate LLM"""
        
        prompt = self.build_prompt(market_data, context)
        
        # NEW: OpenAI branch
        if hasattr(agent, 'llm_provider') and agent.llm_provider == "openai":
            if self._openai:
                raw = await self._openai.generate(prompt)
            else:
                logger.warning("OpenAI not configured, falling back to HOLD")
                return {"action": "hold", "confidence": 0.5, "reason": "OpenAI unavailable"}
        
        # Existing branches (Claude, Ollama)
        elif agent.use_local_llm or (hasattr(agent, 'llm_provider') and agent.llm_provider == "ollama"):
            raw = await self.call_ollama(prompt)
        elif hasattr(agent, 'llm_provider') and agent.llm_provider == "claude":
            raw = await self.call_claude(prompt)
        else:
            # Default to Ollama
            raw = await self.call_ollama(prompt)
        
        decision = self.parse_decision(raw)
        return decision
