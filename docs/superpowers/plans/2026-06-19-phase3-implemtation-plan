pythonfrom datetime import date

class DailySnapshot(Base):
    """Daily performance snapshot for each agent (EOD)"""
    __tablename__ = "daily_snapshots"
    
    id = Column(Integer, primary_key=True, autoincrement=True)
    agent_id = Column(String, ForeignKey("agents.id"), nullable=False, index=True)
    snapshot_date = Column(Date, nullable=False)  # Date, not DateTime
    total_pnl = Column(Float, nullable=False, default=0.0)
    daily_return_pct = Column(Float, nullable=False, default=0.0)  # Return on that day only
    sharpe_ratio = Column(Float, nullable=True)  # Annualized, based on last 30 days
    max_drawdown = Column(Float, nullable=True)  # Worst drawdown to date
    win_rate = Column(Float, nullable=True)  # Winning trades / total trades
    trade_count = Column(Integer, nullable=False, default=0)
    created_at = Column(DateTime, default=datetime.utcnow)
    
    __table_args__ = (
        UniqueConstraint('agent_id', 'snapshot_date', name='uq_agent_date'),
    )
    
    agent = relationship("Agent", back_populates="daily_snapshots")


class BacktestResult(Base):
    """Historical backtest run results"""
    __tablename__ = "backtest_results"
    
    id = Column(String(36), primary_key=True)  # UUID
    agent_id = Column(String, ForeignKey("agents.id"), nullable=False, index=True)
    run_at = Column(DateTime, nullable=False, default=datetime.utcnow)
    start_date = Column(Date, nullable=False)
    end_date = Column(Date, nullable=False)
    mode = Column(String(20), nullable=False)  # 'basic' or 'walk_forward'
    status = Column(String(20), nullable=False)  # 'running', 'done', 'failed'
    result_json = Column(JSON, nullable=True)  # {total_return_pct, win_rate, sharpe_ratio, max_drawdown, ...}
    error_message = Column(String, nullable=True)  # If status='failed'
    created_at = Column(DateTime, default=datetime.utcnow)
    
    agent = relationship("Agent", back_populates="backtest_results")


# Update Agent model to add relationships
