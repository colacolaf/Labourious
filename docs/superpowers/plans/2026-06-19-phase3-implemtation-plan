def test_compute_sharpe_basic():
    """Test Sharpe ratio calculation"""
    # 30 daily returns, annualized: mean/std * sqrt(252)
    daily_returns = [0.01, 0.02, -0.01, 0.015, 0.005] * 6  # 30 values
    sharpe = compute_sharpe(daily_returns, risk_free_rate=0.0)
    assert isinstance(sharpe, float)
    assert sharpe > 0  # Positive trend, positive sharpe

def test_compute_sharpe_zero_volatility():
    """Test Sharpe with zero std dev (no volatility)"""
    daily_returns = [0.01] * 30  # All same return
    sharpe = compute_sharpe(daily_returns)
    # std dev ~ 0, sharpe should be large (actually undefined, but we return 0.0)
    assert sharpe >= 0  # Not NaN

def test_compute_sharpe_insufficient_data():
    """Test Sharpe with fewer than 2 data points"""
    assert compute_sharpe([0.01]) == 0.0
    assert compute_sharpe([]) == 0.0

def test_compute_max_drawdown_basic():
    """Test max drawdown calculation"""
    equity = [100, 105, 110, 115, 110, 105, 100, 95, 100, 110]
    # Peak: 115, trough: 95, drawdown = (95-115)/115 = -17.39%
    max_dd = compute_max_drawdown(equity)
    assert abs(max_dd - (-0.1739)) < 0.001

def test_compute_max_drawdown_all_up():
    """Test max drawdown when only going up"""
    equity = [100, 105, 110, 115, 120]
    max_dd = compute_max_drawdown(equity)
    assert max_dd == 0.0  # No drawdown

def test_compute_max_drawdown_empty():
